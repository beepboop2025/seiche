# Secrets for a Seiche desk agent. Copy the lines you need into ~/.hermes/.env
# (hermes reads .env with precedence over config.yaml for secrets).

# Model provider (pick the one matching config.yaml)
OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# Telegram gateway
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric user ids allowed to talk to the bot. Leave unset
# and the bot answers no one; never run an open bot with subscriber tools.
TELEGRAM_ALLOWED_USERS=
# Default chat for scheduled deliveries (cron briefs, alerts)
TELEGRAM_HOME_CHANNEL=

# Seiche stdio server surface (only for wiring (a); the free surface)
# SEICHE_MCP_PUBLIC=1
